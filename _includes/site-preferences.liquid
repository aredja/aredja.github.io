<style>
  .toggle-container,
  #search-toggle {
    display: none !important;
  }

  .profile-links {
    float: right;
    width: 190px;
    margin: 0 0 1.5rem 2.5rem;
    padding-left: 1.25rem;
    border-left: 1px solid var(--global-divider-color);
    font-size: 0.95rem;
    line-height: 1.9;
  }

  .profile-photo {
    display: block;
    width: 150px;
    height: 150px;
    margin: 0 0 1rem;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid var(--global-divider-color);
  }

  .profile-links a,
  .profile-links span {
    display: block;
    color: var(--global-text-color);
    text-decoration: none;
  }

  .profile-links a:hover {
    color: var(--global-theme-color);
  }

  .profile-links i {
    width: 1.25rem;
    margin-right: 0.35rem;
    text-align: center;
    color: var(--global-theme-color);
  }

  .cv-actions {
    margin-bottom: 1rem;
  }

  .cv-download {
    color: var(--global-text-color);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .cv-embed {
    width: 100%;
    height: 78vh;
    min-height: 720px;
    border: 1px solid var(--global-divider-color);
    background: #ffffff;
  }

  @media (max-width: 575px) {
    .profile-links {
      float: none;
      width: auto;
      margin: 0 0 1.5rem;
      padding: 0 0 1rem;
      border-left: 0;
      border-bottom: 1px solid var(--global-divider-color);
    }

    .profile-links a,
    .profile-links span {
      display: inline-block;
      margin-right: 1rem;
    }

    .profile-photo {
      width: 120px;
      height: 120px;
      margin-bottom: 1rem;
    }

    .cv-embed {
      height: 70vh;
      min-height: 560px;
    }
  }
</style>

<script>
  localStorage.setItem("theme", "dark");
  if (typeof setThemeSetting === "function") {
    setThemeSetting("dark");
  } else {
    document.documentElement.setAttribute("data-theme-setting", "dark");
    document.documentElement.setAttribute("data-theme", "dark");
  }
</script>
