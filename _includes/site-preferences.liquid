<style>
  .toggle-container,
  #search-toggle {
    display: none !important;
  }

  .navbar-brand .font-weight-bold,
  .post-title .font-weight-bold {
    font-weight: inherit !important;
  }

  .profile-links {
    float: right;
    width: 190px;
    margin: 0 0 1.5rem 2.5rem;
    padding-left: 1.25rem;
    border-left: 1px solid var(--global-divider-color);
    font-size: 0.95rem;
    line-height: 1.9;
  }

  .profile-photo {
    display: block;
    width: 150px;
    height: 150px;
    margin: 0 0 1rem;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid var(--global-divider-color);
  }

  .profile-links a,
  .profile-links span {
    display: block;
    color: var(--global-text-color);
    text-decoration: none;
  }

  .profile-links a:hover {
    color: var(--global-theme-color);
  }

  .profile-links i {
    width: 1.25rem;
    margin-right: 0.35rem;
    text-align: center;
    color: var(--global-theme-color);
  }

  .cv-actions {
    margin-bottom: 1rem;
  }

  .cv-download {
    color: var(--global-text-color);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .cv-embed {
    width: 100%;
    height: 78vh;
    min-height: 720px;
    border: 1px solid var(--global-divider-color);
    background: #ffffff;
  }

  .coffee-map {
    width: 100%;
    height: min(58vh, 520px);
    min-height: 360px;
    margin: 1.5rem 0 2.25rem;
    border: 1px solid var(--global-divider-color);
    border-radius: 6px;
    background: #e5e3df;
  }

  .coffee-list {
    border-top: 1px solid var(--global-divider-color);
  }

  .coffee-entry {
    border-bottom: 1px solid var(--global-divider-color);
  }

  .coffee-summary {
    display: block;
    padding: 1.75rem 0;
    cursor: pointer;
    list-style: none;
  }

  .coffee-summary::-webkit-details-marker {
    display: none;
  }

  .coffee-summary:hover h2,
  .coffee-summary:focus-visible h2 {
    color: var(--global-theme-color);
  }

  .coffee-summary:focus-visible {
    outline: 2px solid var(--global-theme-color);
    outline-offset: 5px;
  }

  .coffee-entry-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .coffee-entry h2 {
    margin: 0 0 0.2rem;
    font-size: 1.55rem;
  }

  .coffee-location {
    margin: 0;
    color: var(--global-text-color-light);
  }

  .coffee-location i {
    margin-right: 0.3rem;
    color: var(--global-theme-color);
  }

  .coffee-overall {
    display: flex;
    align-items: baseline;
    flex: 0 0 auto;
    color: var(--global-text-color);
  }

  .coffee-overall strong {
    font-size: 2rem;
    line-height: 1;
    font-weight: 600;
  }

  .coffee-overall span {
    margin-left: 0.25rem;
    color: var(--global-text-color-light);
    font-size: 0.85rem;
  }

  .coffee-expand-icon {
    margin-left: 0.9rem;
    color: var(--global-text-color-light);
    font-size: 0.8rem;
    transition: transform 180ms ease;
  }

  .coffee-entry[open] .coffee-expand-icon {
    transform: rotate(180deg);
  }

  .coffee-scores {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    max-width: 430px;
    margin: 0 0 1.25rem;
    border-top: 1px solid var(--global-divider-color);
    border-bottom: 1px solid var(--global-divider-color);
  }

  .coffee-scores div {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.55rem 0.8rem;
    border-right: 1px solid var(--global-divider-color);
  }

  .coffee-scores div:first-child {
    padding-left: 0;
  }

  .coffee-scores div:last-child {
    border-right: 0;
  }

  .coffee-scores dt,
  .coffee-scores dd {
    margin: 0;
  }

  .coffee-scores dt {
    color: var(--global-text-color-light);
    font-weight: 400;
  }

  .coffee-scores dd {
    color: var(--global-text-color);
    font-weight: 600;
  }

  .coffee-personal {
    color: var(--global-text-color);
    font-style: italic;
  }

  .coffee-details {
    padding: 0 0 1.75rem;
  }

  .coffee-gallery {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.25rem 0 0.5rem;
  }

  .coffee-thumbnail {
    width: 150px;
    height: 105px;
    padding: 0;
    overflow: hidden;
    border: 1px solid var(--global-divider-color);
    border-radius: 5px;
    background: transparent;
    cursor: zoom-in;
  }

  .coffee-thumbnail img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 180ms ease;
  }

  .coffee-thumbnail:hover img,
  .coffee-thumbnail:focus-visible img {
    transform: scale(1.04);
  }

  .coffee-image-credit {
    margin: 0;
    color: var(--global-text-color-light);
    font-size: 0.8rem;
  }

  .coffee-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem;
    margin-top: 1.25rem;
  }

  .coffee-show-map {
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--global-theme-color);
    font: inherit;
    cursor: pointer;
  }

  .coffee-actions i {
    margin: 0 0.25rem;
    font-size: 0.85em;
  }

  .coffee-popup {
    display: grid;
    gap: 0.15rem;
    min-width: 140px;
    color: #000000;
  }

  .coffee-popup strong {
    font-size: 1rem;
  }

  .coffee-map .leaflet-popup-content,
  .coffee-map .leaflet-popup-content-wrapper,
  .coffee-map .leaflet-popup-content-wrapper *,
  .coffee-map .leaflet-popup-content strong,
  .coffee-map .leaflet-popup-content span {
    color: #000000 !important;
    opacity: 1;
  }

  .coffee-map .leaflet-popup-content {
    font-weight: 400;
  }

  .coffee-map .leaflet-popup-content strong {
    font-weight: 700;
  }

  .coffee-map .leaflet-popup-content a {
    color: #000000 !important;
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .coffee-lightbox {
    width: min(92vw, 1100px);
    max-width: none;
    height: min(88vh, 820px);
    max-height: none;
    padding: 0;
    overflow: hidden;
    border: 1px solid #555555;
    border-radius: 6px;
    background: #111111;
    color: #ffffff;
  }

  .coffee-lightbox:not([open]),
  .coffee-lightbox button[hidden] {
    display: none;
  }

  .coffee-lightbox::backdrop {
    background: rgba(0, 0, 0, 0.88);
  }

  .coffee-lightbox figure {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 3.5rem 5rem 2.25rem;
  }

  .coffee-lightbox figure img {
    display: block;
    max-width: 100%;
    max-height: calc(100% - 2rem);
    object-fit: contain;
  }

  .coffee-lightbox figcaption {
    margin-top: 0.75rem;
    color: #ffffff;
    font-size: 0.9rem;
    text-align: center;
  }

  .coffee-lightbox-close,
  .coffee-lightbox-previous,
  .coffee-lightbox-next {
    position: absolute;
    z-index: 1;
    display: grid;
    width: 42px;
    height: 42px;
    padding: 0;
    place-items: center;
    border: 0;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.65);
    color: #ffffff;
    cursor: pointer;
  }

  .coffee-lightbox-close {
    top: 0.75rem;
    right: 0.75rem;
  }

  .coffee-lightbox-previous,
  .coffee-lightbox-next {
    top: 50%;
    transform: translateY(-50%);
  }

  .coffee-lightbox-previous {
    left: 0.75rem;
  }

  .coffee-lightbox-next {
    right: 0.75rem;
  }

  .coffee-lightbox button:hover,
  .coffee-lightbox button:focus-visible {
    background: rgba(0, 0, 0, 0.92);
    outline: 2px solid #ffffff;
  }

  @media (max-width: 575px) {
    .profile-links {
      float: none;
      width: auto;
      margin: 0 0 1.5rem;
      padding: 0 0 1rem;
      border-left: 0;
      border-bottom: 1px solid var(--global-divider-color);
    }

    .profile-links a,
    .profile-links span {
      display: inline-block;
      margin-right: 1rem;
    }

    .profile-photo {
      width: 120px;
      height: 120px;
      margin-bottom: 1rem;
    }

    .cv-embed {
      height: 70vh;
      min-height: 560px;
    }

    .coffee-map {
      height: 55vh;
      min-height: 320px;
    }

    .coffee-scores {
      grid-template-columns: 1fr;
    }

    .coffee-scores div,
    .coffee-scores div:first-child {
      padding: 0.45rem 0;
      border-right: 0;
      border-bottom: 1px solid var(--global-divider-color);
    }

    .coffee-scores div:last-child {
      border-bottom: 0;
    }

    .coffee-summary {
      padding: 1.35rem 0;
    }

    .coffee-thumbnail {
      width: 120px;
      height: 84px;
    }

    .coffee-lightbox {
      width: 96vw;
      height: 82vh;
    }

    .coffee-lightbox figure {
      padding: 3.5rem 3rem 2rem;
    }
  }
</style>

<script>
  localStorage.setItem("theme", "dark");
  if (typeof setThemeSetting === "function") {
    setThemeSetting("dark");
  } else {
    document.documentElement.setAttribute("data-theme-setting", "dark");
    document.documentElement.setAttribute("data-theme", "dark");
  }
</script>
